{
  "name": "@cortexkit/openai-auth",
  "private": true,
  "type": "module",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "build": "cd packages/opencode && bun run build",
    "typecheck": "cd packages/opencode && bun run typecheck",
    "types": "bun run typecheck",
    "pack:opencode:dry": "cd packages/opencode && bun pm pack --dry-run",
    "prepublishOnly": "bun run build"
  },
  "devDependencies": {
    "@opencode-ai/plugin": "1.17.1",
    "@tsconfig/bun": "1.0.10",
    "@types/bun": "1.3.14",
    "bun-types": "1.3.14",
    "typescript": "6.0.3"
  }
}
